{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyMD",
  "version": "2.2.0",
  "identifier": "com.easymd.app",
  "build": {
    "beforeDevCommand": {
      "script": "node scripts/desktop-dev-prepare.mjs",
      "cwd": "../../.."
    },
    "devUrl": "http://127.0.0.1:5173/md/",
    "beforeBuildCommand": {
      "script": "pnpm --filter @md/web build:desktop",
      "cwd": "../../.."
    },
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "**/*"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "EasyMD",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "EasyMD — Markdown editor",
    "longDescription": "EasyMD is a lightweight Markdown editor with live preview and desktop file integration.",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ]
  },
  "plugins": {}
}
